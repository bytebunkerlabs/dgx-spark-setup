# =============================================================================
#  DGX Spark setup — central configuration
#  Copy to .env and edit:   cp .env.example .env
#  Everything in here is sourced by the scripts and the docker-compose files.
# =============================================================================

# ---- identity ----------------------------------------------------------------
SPARK_HOSTNAME="spark-01"                 # this node's hostname
TZ="UTC"

# ---- Hugging Face ------------------------------------------------------------
# Needed for gated models (Llama, etc.) and to raise download rate limits.
# Create at https://huggingface.co/settings/tokens  (read scope is enough).
HF_TOKEN=""

# ---- data locations (all live on the fast local NVMe) ------------------------
# UMA note: models are memory-mapped into the shared 128GB pool at load time,
# so keep the on-disk cache on the internal SSD, not a USB drive.
DATA_ROOT="${HOME}/dgx"                    # parent for everything below
HF_HOME="${HOME}/dgx/hf"                   # Hugging Face cache
MODELS_DIR="${HOME}/dgx/models"            # GGUF / local model files
OLLAMA_MODELS="${HOME}/dgx/ollama"         # Ollama blob store

# =============================================================================
#  Container images
#  IMPORTANT: aarch64 + Blackwell (sm_121) is a moving target. VERIFY the tags
#  below before first run against:
#    - NGC catalog:            https://catalog.ngc.nvidia.com
#    - Official playbooks:     https://github.com/NVIDIA/dgx-spark-playbooks
#                              (see the sglang/ and vllm/ READMEs)
#    - Community image index:  https://github.com/bidual/awesome-dgx-spark
#  The defaults are sensible starting points, not guaranteed-current pins.
#  DGX Spark NIM containers require the "-dgx-spark" image variant.
# =============================================================================

# General CUDA dev container (NGC PyTorch is the safe, validated base).
NGC_PYTORCH_IMAGE="nvcr.io/nvidia/pytorch:25.11-py3"          # <-- verify tag

# Inference engines (pick one for the primary endpoint in 05-inference.sh).
VLLM_IMAGE="vllm/vllm-openai:latest"                          # public, no NGC login needed
SGLANG_IMAGE="lmsysorg/sglang:latest-aarch64"                # <-- verify tag
TRTLLM_IMAGE="nvcr.io/nvidia/tensorrt-llm:25.11-py3"          # <-- verify tag

# Supporting services (these are arch-generic and stable).
LITELLM_IMAGE="ghcr.io/berriai/litellm:main-latest"
OPENWEBUI_IMAGE="ghcr.io/open-webui/open-webui:main"
PGVECTOR_IMAGE="pgvector/pgvector:pg16"
PROMETHEUS_IMAGE="prom/prometheus:latest"
GRAFANA_IMAGE="grafana/grafana:latest"
NODE_EXPORTER_IMAGE="quay.io/prometheus/node-exporter:latest"
# DCGM does NOT work on GB10 (NVML is memory-blind on unified memory, returns
# garbage). Use an nvidia-smi-based exporter instead — this image is multi-arch,
# so Docker pulls the correct arm64 variant automatically.
GPU_EXPORTER_IMAGE="utkuozdemir/nvidia_gpu_exporter:latest"

# ---- primary served model ----------------------------------------------------
# Blackwell throughput tip: prefer NVFP4 / MXFP4 quantized weights where you can.
# The 8-20B band is the Spark sweet spot for latency; go bigger for quality.
PRIMARY_MODEL="Qwen/Qwen2.5-32B-Instruct"  # HF repo id served by vLLM/SGLang
SERVED_MODEL_NAME="primary"                # name your apps call it by
INFER_ENGINE="vllm"                        # vllm | sglang
INFER_PORT="8001"                          # single-node engine host port (cluster 'big' mode owns 8000)
INFER_MAX_MODEL_LEN="16384"

# Embeddings for RAG (served by the already-installed Ollama for reliability).
EMBED_MODEL="nomic-embed-text"

# ---- gateway / apps ----------------------------------------------------------
LITELLM_PORT="4000"                        # single OpenAI front door (your agents -> here)
LITELLM_MASTER_KEY="sk-change-me"          # REPLACE: openssl rand -hex 24
OPENWEBUI_PORT="3000"

# ---- RAG / Postgres  ------------------------------------------------
PG_PORT="5432"
PG_USER="rag"
PG_PASSWORD="change-me-strong"
PG_DB="rag"

# ---- observability -----------------------------------------------------------
PROMETHEUS_PORT="9090"
GRAFANA_PORT="3001"
GRAFANA_ADMIN_PASSWORD="change-me"
NODE_EXPORTER_PORT="9100"
GPU_EXPORTER_PORT="9835"

# ---- two-Spark cluster (08-cluster.sh) ---------------------------------------
# NOTE: the QSFP link negotiates 200GbE but the ConnectX-7 sits on a PCIe Gen5
# x4 lane, so real cross-node throughput tops out around ~100 Gbps. Plan model
# sharding around that; for many workloads two independent nodes beat one
# tightly-sharded pair. Authoritative multi-node bring-up lives in the official
# "connect-two-sparks" playbook — this repo only stages + validates the link.
CLUSTER_LOCAL_IP="192.168.100.1"           # this node, on the QSFP point-to-point link
CLUSTER_PEER_IP="192.168.100.2"            # the other Spark
CLUSTER_MTU="9000"                         # jumbo frames

# ---- pooled multi-node serving  (10-cluster-serve.sh) ------------------------
# Serves ONE big model split across BOTH Sparks (tensor parallel, via Ray). This
# wraps the community repo mark-ramsey-ri/vllm-dgx-spark, which does the pooled
# serving your platform's single-node engine can't. This is "big" mode; the
# engine above is "fast" mode — they're MUTUALLY EXCLUSIVE on memory, since a big
# TP model claims most of both boxes' 128 GB. You already staged + validated the
# fabric with 09-cluster.sh, so its OS-setup section is skipped entirely.
CLUSTER_REPO_URL="https://github.com/mark-ramsey-ri/vllm-dgx-spark.git"
CLUSTER_VENDOR_DIR="${DATA_ROOT}/vendor/vllm-dgx-spark"   # where the repo is cloned
CLUSTER_WORKER_MGMT=""                     # worker (spark-2) LAN/Tailscale IP the HEAD SSHes to
CLUSTER_QSFP_IFACE=""                     # QSFP iface for multinode (e.g. enp1s0f0np0); 09-cluster detect prints it
CLUSTER_WORKER_USER="${USER}"              # same username on both Sparks (head SSHes as this)
# The worker's NCCL/RDMA IP is CLUSTER_PEER_IP above (your CX7 static IP = the IB IP).
BIG_MODEL="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"  # a 2-Spark preset (switch_model.sh --list)
BIG_TP="2"                                 # tensor parallel = 1 head + N workers
BIG_PORT="8000"                            # cluster head OpenAI endpoint (keep off INFER_PORT)
BIG_GPU_MEM_UTIL="0.90"
BIG_MAX_MODEL_LEN="8192"

# ---- multi-node test lab  (11-multinode.sh) ---------------------------------
# Your own TP/PP experiment rig. Reuses BIG_MODEL / BIG_PORT / BIG_TP /
# BIG_MAX_MODEL_LEN / BIG_GPU_MEM_UTIL and the CLUSTER_* fabric vars above.
RAY_PORT="6379"                            # Ray head port (over the fabric link)
NCCL_IB_HCA=""                             # RDMA device (blank = auto-detect from CLUSTER_QSFP_IFACE, e.g. rocep1s0f0)
# Benchmark defaults (override inline: BENCH_CONCURRENCY=32 ./setup.sh multinode bench pp)
BENCH_CONCURRENCY="8"
BENCH_INPUT_TOKENS="512"
BENCH_OUTPUT_TOKENS="128"
